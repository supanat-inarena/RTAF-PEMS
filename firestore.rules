rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read, write: if true;
    }

    match /requests/{requestId} {
      allow read, write: if true;
    }

    match /inventory/{itemId} {
      allow read, write: if true;
    }

    match /test/{docId} {
      allow read, write: if true;
    }

    match /auditLogs/{logId} {
      allow read, write: if true;
    }
  }
}
